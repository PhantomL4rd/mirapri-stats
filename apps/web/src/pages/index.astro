---
import BaseLayout from '../layouts/BaseLayout.astro';
import PrivacyRibbon from '../components/PrivacyRibbon.astro';
import SlotTabs from '../components/SlotTabs.svelte';
import TrendRanking from '../components/TrendRanking.astro';
import { getTrendingUp, getDataFreshness } from '../lib/queries';
import { SLOT_IDS, parseSlotParam, resolveVersionContext } from '../lib/db';

// クエリパラメータからスロットとバージョンを取得
const url = new URL(Astro.request.url);
const currentSlot = parseSlotParam(url.searchParams.get('slot'));
const versionParam = url.searchParams.get('version');
const slotId = SLOT_IDS[currentSlot] ?? 2;

// D1からデータ取得
const db = Astro.locals.runtime.env.DB;
let trendItems: Awaited<ReturnType<typeof getTrendingUp>> = [];
let freshness: Awaited<ReturnType<typeof getDataFreshness>> = { dataFrom: null, dataTo: null };
let ctx = { versions: [] as Awaited<ReturnType<typeof import('../lib/db').getAvailableVersions>>, currentVersion: '', isActiveVersion: true, linkVersion: undefined as string | undefined, shouldRedirect: false };

try {
  ctx = await resolveVersionContext(db, versionParam);

  if (ctx.shouldRedirect) {
    const redirectUrl = new URL(url);
    redirectUrl.searchParams.delete('version');
    return Astro.redirect(redirectUrl.pathname + redirectUrl.search);
  }

  [trendItems, freshness] = await Promise.all([
    getTrendingUp(db, slotId, 10, ctx.currentVersion),
    getDataFreshness(db, ctx.currentVersion),
  ]);
} catch (e) {
  console.error('D1 query error:', e);
}
---

<BaseLayout title={`ミラプリインサイト`} versions={ctx.versions} currentVersion={ctx.currentVersion} freshness={freshness}>
  <PrivacyRibbon slot="ribbon" />

  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-balance">今月の急上昇ミラプリ</h1>
      <p class="mt-1 text-sm text-muted-foreground">
        前回の更新から使用数が伸びたアイテム
      </p>
    </div>

    <SlotTabs currentSlot={currentSlot} version={ctx.linkVersion} client:load />

    <TrendRanking items={trendItems} version={ctx.linkVersion} />
  </div>
</BaseLayout>
