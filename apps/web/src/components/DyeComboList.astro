---
import type { DyeComboResult } from '../lib/queries';

interface Props {
  combos: DyeComboResult[];
}

const { combos } = Astro.props;

const TOP_N = 3;
const topCombos = combos.slice(0, TOP_N);
const restCombos = combos.slice(TOP_N);

function rgbStyle(rgb: { r: number; g: number; b: number } | null): string {
  if (!rgb) return '';
  return `background-color: rgb(${rgb.r}, ${rgb.g}, ${rgb.b});`;
}
---

<div class="space-y-2">
  {
    combos.length === 0 ? (
      <p class="text-center text-muted-foreground py-6 text-sm">
        この装備の染色組み合わせデータはまだありません
      </p>
    ) : (
      <>
        <ol class="space-y-2">
          {topCombos.map((c) => (
            <li class="flex items-center gap-3 rounded-lg border border-border bg-card p-3 shadow-sm">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 text-sm">
                  <div class="flex items-center gap-1.5">
                    {c.stain1Rgb ? (
                      <span
                        class="inline-block size-4 rounded border border-border/60"
                        style={rgbStyle(c.stain1Rgb)}
                        aria-hidden="true"
                      />
                    ) : (
                      <span
                        class="inline-block size-4 rounded border border-dashed border-muted-foreground/40"
                        aria-hidden="true"
                      />
                    )}
                    <span class={c.stain1Name ? 'font-medium' : 'text-muted-foreground'}>
                      {c.stain1Name ?? '未染色'}
                    </span>
                  </div>
                  <span class="text-muted-foreground">/</span>
                  <div class="flex items-center gap-1.5">
                    {c.stain2Rgb ? (
                      <span
                        class="inline-block size-4 rounded border border-border/60"
                        style={rgbStyle(c.stain2Rgb)}
                        aria-hidden="true"
                      />
                    ) : (
                      <span
                        class="inline-block size-4 rounded border border-dashed border-muted-foreground/40"
                        aria-hidden="true"
                      />
                    )}
                    <span class={c.stain2Name ? 'font-medium' : 'text-muted-foreground'}>
                      {c.stain2Name ?? '未染色'}
                    </span>
                  </div>
                </div>
              </div>
            </li>
          ))}
        </ol>
        {restCombos.length > 0 && (
          <details class="group">
            <summary class="cursor-pointer text-sm text-muted-foreground hover:text-foreground py-2">
              さらに {restCombos.length} 件を表示
            </summary>
            <ol class="space-y-2 mt-2">
              {restCombos.map((c) => (
                <li class="flex items-center gap-3 rounded-lg border border-border bg-card p-3 shadow-sm">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-3 text-sm">
                      <div class="flex items-center gap-1.5">
                        {c.stain1Rgb ? (
                          <span
                            class="inline-block size-4 rounded border border-border/60"
                            style={rgbStyle(c.stain1Rgb)}
                            aria-hidden="true"
                          />
                        ) : (
                          <span
                            class="inline-block size-4 rounded border border-dashed border-muted-foreground/40"
                            aria-hidden="true"
                          />
                        )}
                        <span class={c.stain1Name ? 'font-medium' : 'text-muted-foreground'}>
                          {c.stain1Name ?? '未染色'}
                        </span>
                      </div>
                      <span class="text-muted-foreground">/</span>
                      <div class="flex items-center gap-1.5">
                        {c.stain2Rgb ? (
                          <span
                            class="inline-block size-4 rounded border border-border/60"
                            style={rgbStyle(c.stain2Rgb)}
                            aria-hidden="true"
                          />
                        ) : (
                          <span
                            class="inline-block size-4 rounded border border-dashed border-muted-foreground/40"
                            aria-hidden="true"
                          />
                        )}
                        <span class={c.stain2Name ? 'font-medium' : 'text-muted-foreground'}>
                          {c.stain2Name ?? '未染色'}
                        </span>
                      </div>
                    </div>
                  </div>
                </li>
              ))}
            </ol>
          </details>
        )}
      </>
    )
  }
</div>
